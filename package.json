    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.13.3",
    "sharedcorelib": "file:../sharedCoreLib",
    "tailwind-merge": "^2.5.4",
