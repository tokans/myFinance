    "postcss": "^8.4.49",
    "sharedcorelib-publisher-ci": "file:../sharedCoreLib/publisher-ci",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "webdriverio": "^9.27.2"
