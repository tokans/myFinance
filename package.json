    "tauri:ios:init": "tauri ios init",
    "tauri:ios:dev": "tauri ios dev",
    "ios:plist": "node scripts/ensure-ios-plist.mjs",
    "demo:reset": "tsx demo/reset.ts",
    "demo:build": "tsx demo/build.ts",
    "demo:single": "tsx demo/record.ts",
    "demo:all": "tsx demo/record.ts --all",
    "demo:gifs": "tsx demo/record.ts --gifs",
    "demo:video": "tsx demo/edit/render.ts",
    "demo:video:marketing": "tsx demo/edit/render.ts marketing",
    "demo:video:tutorial": "tsx demo/edit/tutorial.ts",
    "demo:marketing": "tsx demo/record.ts --all && tsx demo/edit/render.ts marketing",
    "demo:tutorial": "tsx demo/record.ts 20-full-tutorial && tsx demo/edit/tutorial.ts",
    "masters:keys": "tsx scripts/gen-master-keys.ts",
    "masters:pack": "tsx scripts/pack-masters.ts",
    "masters:sign": "tsx scripts/sign-masters.ts",
    "patron:keys": "tsx scripts/make-patron-file.ts --keygen",
